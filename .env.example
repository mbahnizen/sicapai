# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com — free, 1500 req/day (NOT Google Cloud billing)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=sicapai-mbahnizen

# Option A (local dev): path to downloaded service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option B (Cloud Run): full JSON content as a single-line string
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"sicapai-mbahnizen",...}

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
