# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Dapatkan dari https://aistudio.google.com — gratis, 1500 request/hari
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id

# Opsi A (dev lokal): path ke file service-account.json yang didownload
# GOOGLE_APPLICATION_CREDENTIALS=./server/service-account.json

# Opsi B (Cloud Run): isi JSON sebagai string satu baris
# Dapatkan dari Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
